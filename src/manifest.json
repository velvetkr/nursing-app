{
  "name": "智慧护理",
  "appid": "__UNI__NURSING_APP",
  "description": "互联网+智慧护理移动护理平台",
  "versionName": "1.0.0",
  "versionCode": "100",
  "transformPx": false,
  "app-plus": {
    "usingComponents": true,
    "nvueStyleCompiler": "uni-app",
    "compilerVersion": 3,
    "splashscreen": {
      "alwaysShowBeforeRender": true,
